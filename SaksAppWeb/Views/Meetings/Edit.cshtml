@model SaksAppWeb.Models.ViewModels.MeetingEditVm

@{
    ViewData["Title"] = "Rediger møte";
}

<h1>Rediger møte</h1>

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Møtedato</label>
            <input class="form-control" asp-for="MeetingDate" type="date" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Løpenummer</label>
            <input class="form-control" asp-for="YearSequenceNumber" type="number" min="1" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Sted</label>
            <input class="form-control" asp-for="Location" />
        </div>
    </div>

    <button class="btn btn-primary" type="submit">Lagre</button>
    <a class="btn btn-secondary" asp-action="Details" asp-route-id="@Model.Id">Avbryt</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
