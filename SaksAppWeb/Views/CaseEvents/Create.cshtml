@model SaksAppWeb.Models.ViewModels.CaseEventCreateVm

@{
    ViewData["Title"] = "Ny hendelse";
}

<h1>Ny hendelse</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Category" class="form-label">Kategori</label>
                <select asp-for="Category" class="form-select">
                    <option value="avvik">Avvik</option>
                    <option value="tiltak">Tiltak</option>
                    <option value="general">Generelt</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label">Beskrivelse</label>
                <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CaseNumbers" class="form-label">Koble til saker (saksnummer, kommaseparert)</label>
                <input asp-for="CaseNumbers" class="form-control" placeholder="f.eks. 12, 15, 23" />
                <div class="form-text">Valgfritt. Skriv inn saksnummer adskilt med komma.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Lagre</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Avbryt</a>
            </div>
        </form>
    </div>
</div>
