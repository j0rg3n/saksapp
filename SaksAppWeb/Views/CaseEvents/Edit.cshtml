@model SaksAppWeb.Models.ViewModels.CaseEventEditVm

@{
    ViewData["Title"] = "Rediger hendelse";
}

<h1>Rediger hendelse</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="Category" class="form-label">Kategori</label>
                <select asp-for="Category" class="form-select">
                    <option value="avvik">Avvik</option>
                    <option value="tiltak">Tiltak</option>
                    <option value="general">Generelt</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label">Beskrivelse</label>
                <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CaseNumbers" class="form-label">Koble til saker (saksnummer, kommaseparert)</label>
                <input asp-for="CaseNumbers" class="form-control" placeholder="f.eks. 12, 15, 23" />
                <div class="form-text">Valgfritt. Skriv inn saksnummer adskilt med komma.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">Lagre</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Avbryt</a>
            </div>
        </form>

        <hr class="my-4" />

        <h5>Vedlegg</h5>

        @if (!Model.Attachments.Any())
        {
            <p class="text-muted">Ingen vedlegg.</p>
        }
        else
        {
            <ul class="list-unstyled mb-3">
                @foreach (var a in Model.Attachments)
                {
                    <li class="d-flex align-items-center gap-2 mb-2">
                        <a asp-controller="Cases" asp-action="DownloadAttachment" asp-route-id="@a.AttachmentId">
                            @a.OriginalFileName
                        </a>
                        <span class="text-muted small">(@a.SizeBytes bytes)</span>
                        <form asp-action="RemoveAttachment" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="linkId" value="@a.LinkId" />
                            <input type="hidden" name="eventId" value="@Model.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit"
                                    onclick="return confirm('Fjern vedlegg?')">Fjern</button>
                        </form>
                    </li>
                }
            </ul>
        }

        <form asp-action="UploadAttachment" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">Last opp vedlegg (PDF eller bilde, maks 10 MB)</label>
                    <input class="form-control" type="file" name="file" />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-primary" type="submit">Last opp</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
