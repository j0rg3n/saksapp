@model SaksAppWeb.Models.ViewModels.MeetingDetailsVm

@{
    ViewData["Title"] = $"Møte {Model.Meeting.Year}/{Model.Meeting.YearSequenceNumber}";
}

<div class="d-flex justify-content-between align-items-start">
    <div>
        <h1>Møte @Model.Meeting.Year/@Model.Meeting.YearSequenceNumber — @Model.Meeting.MeetingDate</h1>
        <div class="text-muted">@Model.Meeting.Location</div>
    </div>
    <div class="text-end">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Meeting.Id">Rediger</a>
        <a class="btn btn-outline-secondary" asp-action="Minutes" asp-route-id="@Model.Meeting.Id">Referat</a>
        <a class="btn btn-outline-primary" asp-action="DownloadAgendaPdf" asp-route-id="@Model.Meeting.Id">Last ned innkalling</a>
        <a class="btn btn-outline-primary" asp-action="DownloadAssigneeReminderPdf" asp-route-id="@Model.Meeting.Id">Last ned purreliste</a>
    </div>
</div>

<hr />

<h2>Dagsorden</h2>

<form asp-action="AddCase" method="post" class="mb-4">
    @Html.AntiForgeryToken()
    <input type="hidden" name="meetingId" value="@Model.Meeting.Id" />

    <div class="row g-2 align-items-end">
        <div class="col-md-8">
            <label class="form-label">Legg til åpen sak</label>
            <select class="form-select" name="caseId" asp-items="Model.OpenCasesToAdd">
                <option value="">-- velg --</option>
            </select>
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary" type="submit">Legg til</button>
        </div>
    </div>
</form>

<table class="table table-sm table-striped">
    <thead>
    <tr>
        <th style="width: 90px;">Rekkefølge</th>
        <th>Sak</th>
        <th>Ansvarlig</th>
        <th>Dagsordenstekst</th>
        <th>Tidsfrist</th>
        <th style="width: 260px;"></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var a in Model.Agenda)
    {
        <tr>
            <td>@a.AgendaOrder</td>
            <td><a asp-controller="Cases" asp-action="Details" asp-route-id="@a.CaseId">#@a.CaseNumber — @a.Title</a></td>
            <td>@a.AssigneeDisplay</td>
            <td style="white-space: pre-wrap">@a.AgendaTextSnapshot</td>
            <td>
                @if (a.TidsfristOverrideDate is not null) { <span>@a.TidsfristOverrideDate</span> }
                @if (!string.IsNullOrWhiteSpace(a.TidsfristOverrideText)) { <span> @a.TidsfristOverrideText</span> }
            </td>
            <td class="text-end">
                <div class="btn-group" role="group">
                    <form asp-action="MoveAgendaItem" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@a.MeetingEventLinkId" />
                        <input type="hidden" name="up" value="true" />
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Opp</button>
                    </form>
                    <form asp-action="MoveAgendaItem" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@a.MeetingEventLinkId" />
                        <input type="hidden" name="up" value="false" />
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Ned</button>
                    </form>
                    <a class="btn btn-sm btn-outline-primary" asp-action="EditAgendaItem" asp-route-id="@a.MeetingEventLinkId">Rediger</a>
                    <form asp-action="RemoveAgendaItem" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@a.MeetingEventLinkId" />
                        <button class="btn btn-sm btn-outline-danger" type="submit"
                                onclick="return confirm('Fjern dette punktet?')">
                            Fjern
                        </button>
                    </form>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
