@model IReadOnlyList<SaksAppWeb.Models.ViewModels.CaseIndexRowVm>
@using SaksAppWeb.Models

@{
    ViewData["Title"] = "Saker";
}

<div class="d-flex justify-content-between align-items-center">
    <h1>Saker</h1>
    <div>
        <form method="get" asp-action="Index" class="d-inline-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input" name="showClosed" id="showClosed" value="true" @(Context.Request.Query["showClosed"].ToString() == "true" ? "checked" : "") onchange="this.form.submit()">
            <label class="form-check-label" for="showClosed">Vis lukkede</label>
        </form>
        <a class="btn btn-primary ms-3" asp-action="Create">Ny sak</a>
    </div>
</div>

<table class="table table-sm table-striped">
    <thead>
    <tr>
        <th>#</th>
        <th>Tittel</th>
        <th>Tema</th>
        <th>Prioritet</th>
        <th>Status</th>
        <th>Ansvarlig</th>
        <th>Tidsfrist</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td><a asp-action="Details" asp-route-id="@c.Id">#@c.CaseNumber</a></td>
            <td>@c.Title</td>
            <td>@c.Theme</td>
            <td>@((int)c.Priority)</td>
            <td>@c.Status</td>
            <td>@c.AssigneeDisplay</td>
            <td>
                @if (c.CustomTidsfristDate is not null)
                {
                    <span>@c.CustomTidsfristDate</span>
                }
                @if (!string.IsNullOrWhiteSpace(c.CustomTidsfristText))
                {
                    <span>@(c.CustomTidsfristDate is not null ? " — " : "")@c.CustomTidsfristText</span>
                }
            </td>
            <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.Id">Åpne</a>
            </td>
        </tr>
    }
    </tbody>
</table>
